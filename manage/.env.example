# Farm Manager Environment Configuration
# Copy this file to .env and fill in your values
# NOTE: If BASE_URL is not set, the app defaults to production backend

# =============================================================================
# Backend API
# =============================================================================
# The base URL for the ML/Memory backend API
# Production (default): https://farm-manager-nxvx.onrender.com
# Local development:    http://localhost:8000
BASE_URL=https://farm-manager-nxvx.onrender.com

# =============================================================================
# Supabase Configuration
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
CALLBACK_URL=https://your-project.supabase.co/auth/v1/callback

# =============================================================================
# Google OAuth
# =============================================================================
GOOGLE_WEB_CLIENT=your-google-web-client-id.apps.googleusercontent.com

# =============================================================================
# AI Services
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key
FEATHERLESS_API_KEY=your-featherless-api-key
